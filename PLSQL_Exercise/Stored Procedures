Scenario 3: Transfer Funds Between Accounts
CREATE OR REPLACE PROCEDURE TransferFunds (
    p_from_account_id IN NUMBER,
    p_to_account_id IN NUMBER,
    p_amount IN NUMBER
) IS
    v_source_balance NUMBER;
BEGIN
    -- Validate transfer amount
    IF p_amount <= 0 THEN
        RAISE_APPLICATION_ERROR(-20002, 'Transfer amount must be greater than zero.');
    END IF;

    -- Check source account balance and lock the row to prevent concurrent updates
    SELECT balance INTO v_source_balance
    FROM accounts
    WHERE account_id = p_from_account_id
    FOR UPDATE; 

    -- Ensure sufficient funds
    IF v_source_balance < p_amount THEN
        RAISE_APPLICATION_ERROR(-20003, 'Insufficient funds in the source account.');
    END IF;

    -- 1. Deduct amount from the source account
    UPDATE accounts
    SET balance = balance - p_amount
    WHERE account_id = p_from_account_id;

    -- 2. Add amount to the destination account
    UPDATE accounts
    SET balance = balance + p_amount
    WHERE account_id = p_to_account_id;

    -- Save both changes together as a single transaction
    COMMIT;
    DBMS_OUTPUT.PUT_LINE('Successfully transferred $' || p_amount || 
                         ' from account ' || p_from_account_id || 
                         ' to account ' || p_to_account_id);
EXCEPTION
    WHEN NO_DATA_FOUND THEN
        -- This triggers if the SELECT statement fails to find the p_from_account_id
        ROLLBACK;
        DBMS_OUTPUT.PUT_LINE('Error: The source account ID does not exist.');
    WHEN OTHERS THEN
        -- Catch any other application errors (like our custom -20003) or system errors
        ROLLBACK;
        DBMS_OUTPUT.PUT_LINE('An error occurred during transfer: ' || SQLERRM);
END TransferFunds;
/
