public class FinancialForecasting {

    // Implementation: Recursive algorithm to calculate future value
    public static double calculateFutureValueRecursive(double presentValue, double growthRate, int periods) {
        // Base Case: If there are no more periods left to calculate, return the value
        if (periods == 0) {
            return presentValue;
        }
        
        // Recursive Step: Get the value from the previous period and apply the growth rate
        double previousValue = calculateFutureValueRecursive(presentValue, growthRate, periods - 1);
        double currentValue = previousValue * (1 + growthRate);
        
        return currentValue;
    }

    public static void main(String[] args) {
        double initialInvestment = 1000.00; // $1,000
        double annualGrowthRate = 0.05;     // 5% growth per year
        int years = 10;                     // forecast for 10 years

        double futureValue = calculateFutureValueRecursive(initialInvestment, annualGrowthRate, years);
        
        System.out.printf("Initial Investment: $%,.2f\n", initialInvestment);
        System.out.printf("Predicted value after %d years: $%,.2f\n", years, futureValue);
    }
}
