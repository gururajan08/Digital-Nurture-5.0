import java.util.Arrays;

public class EcommerceSearch {

    // 1. Setup: Create the Product class
    static class Product implements Comparable<Product> {
        int productId;
        String productName;
        String category;

        public Product(int productId, String productName, String category) {
            this.productId = productId;
            this.productName = productName;
            this.category = category;
        }

        // We implement compareTo so the array can be sorted easily for Binary Search
        @Override
        public int compareTo(Product other) {
            return Integer.compare(this.productId, other.productId);
        }

        @Override
        public String toString() {
            return "Product{ID=" + productId + ", Name='" + productName + "'}";
        }
    }

    // 2. Implementation: Linear Search
    public static Product linearSearch(Product[] products, int targetId) {
        for (Product product : products) {
            if (product.productId == targetId) {
                return product;
            }
        }
        return null; // Not found
    }

    // 2. Implementation: Binary Search
    public static Product binarySearch(Product[] sortedProducts, int targetId) {
        int left = 0;
        int right = sortedProducts.length - 1;

        while (left <= right) {
            int mid = left + (right - left) / 2; // Prevents integer overflow
            
            if (sortedProducts[mid].productId == targetId) {
                return sortedProducts[mid];
            }
            
            if (sortedProducts[mid].productId < targetId) {
                left = mid + 1; // Search the right half
            } else {
                right = mid - 1; // Search the left half
            }
        }
        return null; // Not found
    }

    public static void main(String[] args) {
        // Setup array for Linear Search
        Product[] productsArray = {
            new Product(105, "Wireless Mouse", "Electronics"),
            new Product(101, "Laptop Backpack", "Accessories"),
            new Product(109, "Mechanical Keyboard", "Electronics"),
            new Product(102, "Coffee Mug", "Home"),
            new Product(107, "Desk Lamp", "Home")
        };

        // Setup sorted array for Binary Search
        Product[] sortedProductsArray = productsArray.clone();
        Arrays.sort(sortedProductsArray);

        // --- Testing ---
        System.out.println("--- Linear Search ---");
        System.out.println("Finding 109: " + linearSearch(productsArray, 109));
        System.out.println("Finding 999: " + linearSearch(productsArray, 999));

        System.out.println("\n--- Binary Search ---");
        System.out.println("Finding 102: " + binarySearch(sortedProductsArray, 102));
        System.out.println("Finding 999: " + binarySearch(sortedProductsArray, 999));
    }
}
